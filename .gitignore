# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# uv
# uv.lock is committed

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyright/

# Jupyter
.ipynb_checkpoints/

# Editors
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Generated schematics
tests/*/diagrams/

# Plot artifacts
*.png
*.svg
# …but the bundled glyph library is part of the source tree (res/) and
# also has to ship with the GitHub Pages deployment (docs/res/).
!res/**/*.svg
!docs/res/**/*.svg
!res/sycan.png
!docs/res/sycan.png

.codex
.claude/
